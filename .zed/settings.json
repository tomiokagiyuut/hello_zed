{
  "languages": {
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "on",
      "enable_language_server": true
    }
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path": "/home/yuutid/.cargo/bin/rust-analyzer",
        "arguments": []
      },
      "initialization_options": {
        "check": {
          "command": "clippy"
        },
        "inlayHints": {
          "maxLength": 20,
          "typeHints": {
            "enable": true
          },
          "parameterHints": {
            "enable": true
          }
        }
      }
    }
  }
}